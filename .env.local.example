# ── Neon Auth (Stack Auth) ────────────────────────────────────────────────────
# Get these from: Neon Console → your project → Auth → SDK Setup
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# ── Neon Database ─────────────────────────────────────────────────────────────
# Use the pooled connection string from: Neon Console → your project → Connection Details
# Make sure "Connection pooling" is enabled (Pgbouncer mode)
DATABASE_URL=

# ── Anthropic (optional) ──────────────────────────────────────────────────────
# Set this for a personal deployment where you don't want users entering their own key.
# If unset, users enter their own key in the UI.
ANTHROPIC_API_KEY=
