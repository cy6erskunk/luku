# ── Neon Auth (Better Auth) ───────────────────────────────────────────────────
# The Vercel–Neon integration sets VITE_NEON_AUTH_URL automatically.
# If running locally, set either one:
NEON_AUTH_BASE_URL=
# VITE_NEON_AUTH_URL=   # alternative — picked up automatically if set

# ── Neon Database ─────────────────────────────────────────────────────────────
# Use the pooled connection string from: Neon Console → your project → Connection Details
DATABASE_URL=

# ── Anthropic (optional) ──────────────────────────────────────────────────────
# Set this for a personal deployment where you don't want users entering their own key.
# If unset, users enter their own key in the UI.
ANTHROPIC_API_KEY=
